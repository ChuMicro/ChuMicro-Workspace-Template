# ChuMicro workspace gitignore.
.venv/
__pycache__/
*.pyc
*.mpy
.pytest_cache/

# Generated runtime config msgpacks (regenerated on every deploy).
projects/*/_generated/

# Workspace-wide defaults + credentials in one gitignored file
# (chumicro Decision 0057).  Materialised by `python run.py setup`
# from the chumicro-workspace package's canonical starter — your
# clone holds your wifi password / broker auth and never travels
# with the workspace.
/workspace.yml

# Materialized from the workbench's canonical devices.yml starter
# at setup time and mutated in place by `add-device` / `rename` /
# `probe`.  Per-user / per-host (port paths and UIDs vary), so it
# never travels with the workspace — each contributor builds their
# own with `add-device`.
/devices.yml

# chumicro-dev mode — per-user; gitignored.  When this file exists,
# `python3 run.py setup` walks the chumicro source-checkout path it
# points at and pip-installs every libraries/<name>/ + workbench/<name>/
# as editable instead of resolving them from PyPI.  Different
# contributors keep their checkouts in different places, so this
# never travels with the workspace.
/chumicro-dev.toml

# Workspace-template hides external libs here.  The packages/.gitignore
# inside that dir handles "ignore everything except itself" so the dir
# itself stays tracked.

# Agent scratch space — commit messages, log captures, temporary
# notes.  Tool-owned by convention but never committed.
.scratch/

# IDE / editor noise.
.idea/
.vscode/
.DS_Store
