# ChuMicro workspace gitignore.
.venv/
__pycache__/
*.pyc
*.mpy
.pytest_cache/

# Only the shipped template examples travel with the repo.  Everything
# else under projects/ is the user's to version in their own clone — and
# in this template checkout it's bench scratch (probes, bakes, orphan
# experiments).  Ignore projects/ wholesale so a stray `git add -A`
# can't publish bench work, and re-include exactly the tracked examples.
projects/*
!projects/_template/
!projects/example_sensor/

# Generated runtime config msgpacks (regenerated on every deploy) —
# ignored even inside the re-included examples above.
projects/*/_generated/
libraries/*/examples/_generated/

# workspace.yml — workspace machinery (library_sources, deploy_targets,
# quality, environments).  Gitignored so the auto-populated
# library_sources block (paths into a sibling chumicro/ checkout in
# dev mode) doesn't reach git.  Materialised by ``python run.py setup``
# from the chumicro-workspace package's canonical starter.
/workspace.yml

# secrets.toml — workspace-wide credentials + device defaults that
# flow into ``runtime_config.msgpack`` at deploy time.  Materialised
# on first ``setup`` from the chumicro-workspace package's canonical
# starter — your clone holds your wifi password / broker auth and
# never travels with the workspace.
/secrets.toml

# Materialized from the workbench's canonical devices.yml starter
# at setup time and mutated in place by `add-device` / `rename` /
# `probe`.  Per-user / per-host (port paths and UIDs vary), so it
# never travels with the workspace — each contributor builds their
# own with `add-device`.
/devices.yml

# chumicro-dev mode — per-user; gitignored.  When this file exists,
# `python3 run.py setup` walks the chumicro source-checkout path it
# points at and pip-installs every libraries/<name>/ + workbench/<name>/
# as editable instead of resolving them from PyPI.  Different
# contributors keep their checkouts in different places, so this
# never travels with the workspace.
/chumicro-dev.toml

# Workspace-template hides external libs here.  The packages/.gitignore
# inside that dir handles "ignore everything except itself" so the dir
# itself stays tracked.

# Agent scratch space — commit messages, log captures, temporary
# notes.  Tool-owned by convention but never committed.
.scratch/

# IDE / editor noise.
.idea/
.vscode/
.DS_Store

# TLS material — bench CA certs / keys / DER blobs never travel with
# the template.
*.pem
*.der
